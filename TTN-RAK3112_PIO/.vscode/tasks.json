{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Safe Upload (free serial + upload)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "pkill -f 'cutecom|yat|minicom|picocom|putty|screen' >/dev/null 2>&1 || true; ~/.platformio/penv/bin/platformio run --target upload"
      ],
      "group": "build",
      "problemMatcher": []
    }
  ]
}
